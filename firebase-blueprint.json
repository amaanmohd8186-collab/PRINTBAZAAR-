{
  "entities": {
    "Seller": {
      "title": "Seller",
      "description": "Represents a merchant in the system with full KYC data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "mobile": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "status": {
          "type": "string",
          "enum": ["Draft", "Submitted", "Under Review", "Additional Info Required", "Approved", "Rejected", "Verified", "Suspended"]
        },
        "level": {
          "type": "string",
          "enum": ["Candidate", "Verified", "Premium Seller", "Trusted Seller", "Gold Seller", "Enterprise Seller"]
        },
        "verificationStep": { "type": "integer" },
        "documents": {
          "type": "object",
          "properties": {
            "selfie": { "type": "string" },
            "governmentIdType": { "type": "string" },
            "governmentIdNumber": { "type": "string" },
            "governmentIdFile": { "type": "string" },
            "businessGst": { "type": "string" },
            "businessPan": { "type": "string" },
            "addressLine": { "type": "string" },
            "pincode": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "bankAccountNumber": { "type": "string" },
            "bankIfscCode": { "type": "string" },
            "bankName": { "type": "string" },
            "mobileOtpVerified": { "type": "boolean" },
            "emailOtpVerified": { "type": "boolean" }
          }
        },
        "aiRiskScore": { "type": "integer" },
        "trustScore": { "type": "integer" },
        "aiFraudFlags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "name", "email", "mobile", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile with credits, wallet, and loyalty data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "seller", "admin"] },
        "walletBalance": { "type": "number" },
        "pendingBalance": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "withdrawnAmount": { "type": "number" },
        "aiCredits": { "type": "integer" },
        "loyaltyPoints": { "type": "integer" },
        "ordersCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "Request by a seller to withdraw funds.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "amount": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["Pending", "Approved", "Rejected", "Paid"]
        },
        "bankDetails": { "type": "object" },
        "adminNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sellerId", "amount", "status", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "sellerId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "paymentId": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "items", "total", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Records of financial transactions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "gateway": { "type": "string" },
        "gatewayTransactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "amount", "status"]
    },
    "SocialPost": {
      "title": "Social Post",
      "description": "A social media post in the community feed.",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "caption": { "type": "string" },
        "media": { "type": "array", "items": { "type": "object" } },
        "likesCount": { "type": "integer" },
        "commentCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Follow": {
      "title": "Follow",
      "description": "Social graph connection.",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Challenge": {
      "title": "Challenge",
      "description": "Community design challenge.",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string" },
        "winnerIds": { "type": "array" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System audit logs for tracking actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "entityType": { "type": "string" },
        "entityId": { "type": "string" },
        "details": { "type": "object" },
        "ip": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "action", "createdAt"]
    }
  },
  "firestore": {
    "/sellers/{sellerId}": {
      "schema": "Seller",
      "description": "Collection of seller profiles including KYC documents."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and account settings."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Consumer orders."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment transaction records."
    },
    "/withdrawals/{requestId}": {
      "schema": "WithdrawalRequest",
      "description": "Withdrawal requests from sellers."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Security and activity audit trails."
    },
    "/posts/{postId}": {
      "schema": "SocialPost",
      "description": "Community social posts."
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "User follow relationships."
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "Design challenges."
    },
    "/notifications/{id}": {
      "schema": "object",
      "description": "In-app user notifications."
    },
    "/wishlist/{id}": {
      "schema": "object",
      "description": "User wishlist items."
    },
    "/tickets/{id}": {
      "schema": "object",
      "description": "Support tickets."
    },
    "/templates/{id}": {
      "schema": "object",
      "description": "Product templates."
    },
    "/designs/{id}": {
      "schema": "object",
      "description": "User saved designs."
    }
  }
}
