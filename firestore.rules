rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "musagraphics75@gmail.com" || 
              request.auth.token.email == "gazisiddiqui01@gmail.com" ||
              request.auth.token.email == "amaanmohd8186@gmail.com");
    }

    // --- COLLECTION RULES ---

    // 1. User Profiles
    match /users/{userId} {
      allow read: if (isSignedIn() && (request.auth.uid == userId || isAdmin()));
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && (request.auth.uid == userId || isAdmin()));
      allow delete: if isAdmin();
    }

    // 2. Sellers & Onboarding
    match /sellers/{sellerId} {
      allow read: if (isSignedIn() && (request.auth.uid == sellerId || isAdmin()));
      allow create: if isSignedIn() && request.auth.uid == sellerId;
      allow update: if (isSignedIn() && (request.auth.uid == sellerId || isAdmin()));
      allow delete: if isAdmin();
    }

    // 3. Products (Public Read, Owner/Admin Write)
    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
    }

    // 4. Designs (Owner + Admin)
    match /generated_designs/{designId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 5. Orders (Owner + Seller + Admin)
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          resource.data.sellerId == request.auth.uid ||
          resource.data.customerEmail == request.auth.token.email
      ));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
          resource.data.userId == request.auth.uid || 
          resource.data.sellerId == request.auth.uid ||
          resource.data.customerEmail == request.auth.token.email
      ));
      allow delete: if isAdmin();
    }

    // 6. Payments (Admin Only - Client should not touch directly)
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // 7. Withdrawals (Owner Read/Create, Admin Full)
    match /withdrawals/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.sellerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 8. Quotes (Owner + Admin)
    match /quotes/{quoteId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // 9. Audit Logs (Create only for clients, Admin full access)
    match /audit_logs/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 10. Wallet Transactions (Owner Read - Admin Write)
    match /wallet_transactions/{txId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // 11. Social Posts (Public Read, Signed In Write)
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 12. Follows (Public Read, Signed In Write)
    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 13. Challenges (Public Read, Signed In Write)
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 14. Brand Kits (Owner + Admin)
    match /brandKits/{userId} {
      allow read, write: if (isSignedIn() && (request.auth.uid == userId || isAdmin()));
    }

    // 15. Staff Management (Admin Only)
    match /staff/{staffId} {
      allow read, write: if isAdmin();
    }

    // 16. Business Reports (Admin Only)
    match /business_reports/{reportId} {
      allow read, write: if isAdmin();
    }

    // 17. Platform Settings (Admin Only)
    match /platform_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 18. Diagnostics & Internal (Admin Only)
    match /_diagnostics/{id} {
      allow read, write: if isAdmin();
    }

    // --- FALLBACK ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
