rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "musagraphics75@gmail.com" || 
              request.auth.token.email == "gazisiddiqui01@gmail.com");
    }

    // --- COLLECTION RULES ---

    // 1. User Profiles
    match /users/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Sellers & Onboarding
    match /sellers/{sellerId} {
      allow read: if (isSignedIn() && request.auth.uid == sellerId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == sellerId;
      allow update: if (isSignedIn() && request.auth.uid == sellerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 3. Products (Public Read, Admin Write)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Designs (Owner + Admin)
    match /generated_designs/{designId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // 5. Orders (Owner + Admin)
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.customerEmail == request.auth.token.email));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.customerEmail == request.auth.token.email));
      allow delete: if isAdmin();
    }

    // 6. Payments (Admin Only - Client should not touch directly)
    match /payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // 7. Quotes (Owner + Admin)
    match /quotes/{quoteId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // 9. Audit Logs (Create only for clients, Admin full access)
    match /audit_logs/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 10. Wallet Transactions (Owner Read - Admin Write)
    match /wallet_transactions/{txId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // 11. Social Posts (Public Read, Signed In Write)
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 12. Follows (Public Read, Signed In Write)
    match /follows/{followId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 13. Challenges (Public Read, Signed In Write)
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 14. Diagnostics & Internal (Admin Only)
    match /_diagnostics/{id} {
      allow read, write: if isAdmin();
    }

    // --- FALLBACK ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
